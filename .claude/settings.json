{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash(npm run build)",
      "Bash(npm run dev)",
      "Bash(npm run lint)",
      "Bash(npm run typecheck)",
      "Bash(npm test)",
      "Bash(npm install:*)",
      "Bash(npx tsc:*)",
      "Bash(node --version)",
      "Bash(tee:*)",
      "mcp__playwright__*",
      "Task"
    ]
  }
}
